{
  "expo": {
    "name": "Desi Capcut",
    "slug": "desi-capcut",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f0f"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#0f0f0f"
      },
      "package": "com.desicapcut.app",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "e338c227-0ff0-490e-bf78-5811b43b9776"
      }
    }
  }
}
