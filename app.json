{
  "expo": {
    "name": "Desi Capcut",
    "slug": "desi-capcut",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "image": "./icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.desicapcut.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.desicapcut.app",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Desi Capcut to access your photos/videos",
          "cameraPermission": "Allow Desi Capcut to access your camera"
        }
      ],
      "expo-av",
      "expo-haptics"
    ],
    "extra": {
      "eas": {
        "projectId": "e338c227-0ff0-490e-bf78-5811b43b9776"
      }
    }
  }
}
